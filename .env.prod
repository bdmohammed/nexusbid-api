# ─── PRODUCTION Environment ───────────────────────────────────────────────────
# NEVER commit this file with real values. Inject via CI/CD or server env vars.
# Swagger is DISABLED. PayPal is set to LIVE (not sandbox).
NODE_ENV=prod
FRONTEND_URL=https://nexusbid.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rfp_prod:secure_prod_password@prod-db-host:5432/nexusbid_prod

# ─── JWT & Session ────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-min-64-char-random-string-for-production-generated-by-openssl
CSRF_SECRET=replace-with-min-32-char-random-string-for-production

# ─── PayPal (LIVE) ────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_live_paypal_client_id
PAYPAL_SECRET=your_live_paypal_secret
PAYPAL_ENV=production
PAYPAL_WEBHOOK_ID=your_live_paypal_webhook_id

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_prod_aws_access_key
AWS_SECRET_ACCESS_KEY=your_prod_aws_secret_key
AWS_S3_BUCKET=nexusbid-tenders-prod

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=ses
FROM_EMAIL=noreply@nexusbid.com
ADMIN_EMAIL=admin@nexusbid.com

# ─── Database Seed ────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=superadmin@nexusbid.com
SEED_ADMIN_PASSWORD=ChangeMe123!ProdSuperStrong

# ─── Features ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=false
