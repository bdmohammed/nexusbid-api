# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=rfp-backend
LOG_LEVEL=debug
PORT=3000
FRONTEND_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rfp:rfp@localhost:5432/nexusbid_dev

# ─── JWT & Session ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-min-64-char-random-string-generated-by-openssl-rand-hex-64
# Generate with: openssl rand -hex 32
CSRF_SECRET=replace-with-min-32-char-random-string

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox
# Get from PayPal Developer Dashboard → Webhooks
PAYPAL_WEBHOOK_ID=

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexusbid-tenders-prod

# ─── Resend (Email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_
FROM_EMAIL=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# ─── Database Seed ───────────────────────────────────────────────────────────
# Used by: npm run seed  (creates super-admin if none exists)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=superadmin@yourdomain.com
SEED_ADMIN_PASSWORD=ChangeMe123!Strong

# ─── PM2 Cron Guard (do NOT set manually — PM2 sets this per worker) ─────────
# NODE_APP_INSTANCE=0
