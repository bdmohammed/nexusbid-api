# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=
APP_NAME=
LOG_LEVEL=
PORT=
FRONTEND_CUSTOMER_URL=
FRONTEND_ADMIN_URL=

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── JWT & Session ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-min-64-char-random-string-generated-by-openssl-rand-hex-64
# Generate with: openssl rand -hex 32
CSRF_SECRET=replace-with-min-32-char-random-string

# ─── PayPal ──────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=
# Get from PayPal Developer Dashboard → Webhooks
PAYPAL_WEBHOOK_ID=

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=dummy
FROM_EMAIL=noreply@yourdomain.com
NEXUSBID_SYSTEM_ADMIN_EMAIL=admin@yourdomain.com

# ─── Database Seed ───────────────────────────────────────────────────────────
# Used by: npm run seed  (creates super-admin if none exists)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=superadmin@yourdomain.com
SEED_ADMIN_PASSWORD=ChangeMe123!Strong

# ─── PM2 Cron Guard (do NOT set manually — PM2 sets this per worker) ─────────
# NODE_APP_INSTANCE=0

# ─── Features ─────────────────────────────────────────────────────────────────
SWAGGER_ENABLED=