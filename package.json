{
  "name": "nexusbid-api",
  "version": "1.0.0",
  "description": "NexusBid â€” USA Government RFP/Tender Marketplace REST API",
  "private": true,
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/config/server.ts",
    "start": "node dist/config/server.js",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --watch --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:write": "prettier --write './src/**/*.{ts,js}'",
    "format": "prettier --check './src/**/*.{ts,js}'",
    "test": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles",
    "test:watch": "cross-env NODE_ENV=test jest --runInBand --watch",
    "test:coverage": "cross-env NODE_ENV=test jest --runInBand --coverage --detectOpenHandles",
    "test:ci": "jest --ci --coverage --runInBand",
    "deps:unused": "knip",
    "deps:circular": "madge --circular --extensions ts src",
    "deps:graph": "dependency-cruiser src",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create -d src/config/database.ts",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/database.ts ",
    "migration:run": "cross-env NODE_ENV=local npm run typeorm -- migration:run -d src/config/database.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/database.ts",
    "seed": "ts-node -r tsconfig-paths/register src/database/seed/seed.ts",
    "seed:local": "cross-env NODE_ENV=local ts-node -r tsconfig-paths/register src/database/seed/seed.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "pre-commit": "lint-staged",
    "prebuild": "rimraf dist",
    "preinstall": "",
    "prepare": "husky",
    "fake": "cross-env NODE_ENV=local npx ts-node -r tsconfig-paths/register src/database/generateMissingMigrations.ts",
    "generate:errors": "ts-node ts-morph-script.ts",
    "dev:local": "cross-env NODE_ENV=local nodemon --exec ts-node -r tsconfig-paths/register src/config/server.ts",
    "dev:dev": "cross-env NODE_ENV=dev nodemon --exec ts-node -r tsconfig-paths/register src/config/server.ts",
    "build": "tsc -p tsconfig.json && tsc-alias",
    "migration:run:local": "cross-env NODE_ENV=local npm run migration:run",
    "migration:run:prod": "node node_modules/typeorm/cli.js migration:run -d dist/config/database.js",
    "seed:prod": "node dist/database/seeds/seed.js",
    "test:auth": "cross-env NODE_ENV=test jest --runInBand --detectOpenHandles tests/auth",
    "migration:run:test": "cross-env NODE_ENV=test ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/config/database.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-sesv2": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.3",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.12.0",
    "pidusage": "^4.0.1",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.1",
    "reflect-metadata": "^0.2.2",
    "slugify": "^1.6.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@jest/types": "^30.4.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "knip": "^6.26.0",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-morph": "^28.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.63.0",
    "tsc-alias": "^1.9.1"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "tsc --noEmit"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "scope-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "test",
          "chore",
          "perf",
          "ci",
          "build",
          "revert"
        ]
      ],
      "subject-case": [
        2,
        "always",
        "lower-case"
      ],
      "subject-empty": [
        2,
        "never"
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "body-leading-blank": [
        1,
        "always"
      ],
      "body-max-line-length": [
        2,
        "always",
        100
      ],
      "footer-leading-blank": [
        1,
        "always"
      ]
    }
  }
}
